{
  "name": "lumina-note",
  "version": "1.4.0",
  "private": true,
  "type": "module",
  "main": "out/main/index.js",
  "scripts": {
    "sync-version": "node scripts/sync_version.mjs",
    "prebuild": "node scripts/sync_version.mjs",
    "dev": "electron-vite dev",
    "dev:vite": "vite",
    "dev:cloud": "sh -c 'trap \"kill 0\" EXIT; npm run server:dev & npm run dev:vite'",
    "bundle-node": "node scripts/bundle_node.mjs",
    "opencode:bundle": "node scripts/bundle_opencode.mjs",
    "opencode:smoke": "node scripts/opencode_smoke.mjs",
    "stage:native": "node scripts/stage_native_modules.mjs",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.node.json",
    "build": "npm run typecheck && electron-vite build",
    "build:vite": "tsc && vite build",
    "preview": "electron-vite preview",
    "release:prepare": "node scripts/release_prepare.mjs",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "dist:mac": "electron-builder --mac",
    "dist:win": "electron-builder --win",
    "dist:linux": "electron-builder --linux",
    "server:dev": "cd server && cargo run",
    "server:test": "cd server && cargo test",
    "test": "vitest",
    "test:run": "vitest --run",
    "test:cloud": "sh -c 'npm run test:run -- src/services/cloudSync/client.test.ts src/stores/useCloudSyncStore.test.ts src/components/settings/WebDAVSettings.test.tsx && npm run server:test'",
    "test:e2e:webkit": "WEBKIT_E2E=1 vitest --run src/__tests__/codemirrorSelectAll.webkit.e2e.test.ts",
    "test:repro:flashcard": "vitest --run src/stores/useFlashcardStore.repro.test.ts src/components/flashcard/FlashcardView.repro.test.tsx src/components/flashcard/FlashcardReview.repro.test.tsx src/services/markdown/frontmatter.flashcard.repro.test.ts",
    "test:repro:flashcard:e2e": "FLASHCARD_E2E=1 vitest --run src/__tests__/flashcardReview.chromium.e2e.test.ts",
    "audit:button-tooltips": "node scripts/audit_button_tooltips.mjs",
    "bench": "vitest bench",
    "bench:run": "vitest bench --run"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.71",
    "@ai-sdk/deepseek": "^2.0.29",
    "@ai-sdk/google": "^3.0.64",
    "@ai-sdk/groq": "^3.0.35",
    "@ai-sdk/openai": "^3.0.53",
    "@ai-sdk/openai-compatible": "^2.0.41",
    "@codemirror/commands": "^6.10.0",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.11.3",
    "@codemirror/state": "^6.5.2",
    "@codemirror/view": "^6.38.8",
    "chokidar": "4.0.3",
    "@excalidraw/excalidraw": "^0.18.1",
    "@lezer/markdown": "^1.6.0",
    "@noble/ed25519": "^3.1.0",
    "@noble/hashes": "^2.2.0",
    "@opencode-ai/sdk": "^1.14.20",
    "@openrouter/ai-sdk-provider": "^2.8.0",
    "@tanstack/react-virtual": "^3.13.24",
    "ai": "^6.0.168",
    "clsx": "^2.1.1",
    "codemirror-live-markdown": "0.5.1-alpha.1",
    "electron-updater": "^6.8.3",
    "extract-zip": "^2.0.1",
    "framer-motion": "^12.23.25",
    "html2canvas": "^1.4.1",
    "ignore": "^7.0.5",
    "jspdf": "^4.2.0",
    "katex": "^0.16.11",
    "lowlight": "^3.1.0",
    "lucide-react": "^0.460.0",
    "marked": "^15.0.0",
    "mermaid": "^11.14.0",
    "ollama-ai-provider-v2": "^3.5.0",
    "pdfjs-dist": "^5.4.296",
    "qrcode.react": "^4.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-pdf": "^10.2.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^2.5.4",
    "turndown": "^7.2.0",
    "webdav": "^5.9.0",
    "yaml": "^2.8.2",
    "zod": "^4.1.13",
    "zustand": "^5.0.0"
  },
  "overrides": {
    "lodash-es": "4.18.1",
    "dompurify": "3.4.1",
    "immutable": "4.3.8",
    "uuid": "14.0.0",
    "@excalidraw/excalidraw": {
      "nanoid": "3.3.11"
    },
    "@excalidraw/mermaid-to-excalidraw": {
      "nanoid": "5.0.9"
    }
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/katex": "^0.16.7",
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/turndown": "^5.0.5",
    "@vitejs/plugin-react": "^4.3.3",
    "@vitest/coverage-v8": "^4.1.4",
    "autoprefixer": "^10.4.20",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "fast-check": "^3.23.2",
    "jsdom": "^29.0.2",
    "playwright-core": "^1.57.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3",
    "vite": "^7.3.2",
    "vitest": "^4.1.4"
  }
}
