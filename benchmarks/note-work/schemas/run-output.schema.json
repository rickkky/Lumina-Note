{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lumina-note.dev/schemas/note-work/run-output.v0.1.json",
  "title": "Lumina Note Work Run Output",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "benchmark_id",
    "task_set",
    "fixture_vault",
    "vault_root_absolute_path",
    "system",
    "system_version",
    "model",
    "prompt_template_id",
    "started_at",
    "runs"
  ],
  "properties": {
    "schema_version": { "const": "lumina/note-work-run-output/v0.1" },
    "benchmark_id": { "type": "string" },
    "task_set": { "type": "string" },
    "fixture_vault": { "type": "string" },
    "vault_root_absolute_path": { "type": "string" },
    "system": { "type": "string" },
    "system_version": { "type": "string" },
    "model": {
      "type": "object",
      "additionalProperties": false,
      "required": ["provider", "model"],
      "properties": {
        "provider": { "type": "string" },
        "model": { "type": "string" }
      }
    },
    "prompt_template_id": { "type": "string" },
    "random_seed": { "type": ["integer", "null"] },
    "started_at": { "type": "string" },
    "runs": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "task_id",
          "status",
          "duration_ms",
          "answer",
          "sources_read",
          "candidate_paths_scanned",
          "files_edited",
          "links_suggested",
          "mutation_checks",
          "cost",
          "failure_notes"
        ],
        "properties": {
          "task_id": { "type": "string" },
          "status": {
            "enum": ["completed", "refused", "needs_clarification", "error"]
          },
          "duration_ms": { "type": "integer", "minimum": 0 },
          "answer": { "type": "string" },
          "sources_read": {
            "type": "array",
            "items": { "type": "string" }
          },
          "candidate_paths_scanned": {
            "type": "array",
            "items": { "type": "string" }
          },
          "graph_calls": { "type": "array" },
          "files_edited": {
            "type": "array",
            "items": { "type": "string" }
          },
          "links_suggested": {
            "type": "array",
            "items": { "type": "string", "pattern": "^\\[\\[[^\\]]+\\]\\]$" }
          },
          "mutation_checks": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["path", "check", "passed", "notes"],
              "properties": {
                "path": { "type": "string" },
                "check": { "type": "string" },
                "passed": { "type": "boolean" },
                "notes": { "type": "string" }
              }
            }
          },
          "cost": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "tool_calls",
              "input_tokens",
              "output_tokens",
              "estimated_cost_usd"
            ],
            "properties": {
              "tool_calls": { "type": "integer", "minimum": 0 },
              "input_tokens": { "type": "integer", "minimum": 0 },
              "output_tokens": { "type": "integer", "minimum": 0 },
              "estimated_cost_usd": { "type": "number", "minimum": 0 }
            }
          },
          "failure_notes": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    }
  }
}
